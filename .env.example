# Required
DATABASE_URL=postgres://hookrelay:hookrelay@localhost:5432/hookrelay?sslmode=disable
JWT_SECRET=your-secret-key-here

# OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# PubSub
PUBSUB_DRIVER=memory
REDIS_URL=redis://localhost:6379

# Server
WORKER_POOL_SIZE=10
PORT=8080
